<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Shell theme — Compose (DagbokenTheme) handles all real theming -->
    <style name="Theme.Dagboken" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- Splash screen: brand blue circle on dark background -->
    <style name="Theme.Dagboken.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#060b0e</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Dagboken</item>
    </style>
</resources>
